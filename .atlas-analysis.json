  "keyFeatures": [
    "Unified risk scoring with DREAD, STRIDE, and CVSS v3.1",
    "Automated CVE data import from NIST NVD",
    "Team-based workspaces with role-based access control",
    "Executive-ready PDF and CSV report generation",
    "Built-in research blog with OWASP Top 10 analysis",
    "Dark-mode first UI for long operational sessions"
  ],
  "publicApiSurface": [
    "/api/auth - NextAuth.js authentication endpoints",
    "Server Actions: createVulnerability, updateVulnerability, deleteVulnerability",
    "Server Actions: calculateDreadScore, applyStrideFramework",
    "Server Actions: generateReport, exportToPDF, exportToCSV",
    "Server Actions: inviteUser, updateUserRole, removeUser",
    "Server Actions: fetchCveData, importCveData",
    "Server Actions: createTeam, updateTeam, deleteTeam"
  ]
